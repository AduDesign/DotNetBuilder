<AduSkin:AduWindow
    x:Class="DotNetBuilder.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:AduAttach="clr-namespace:AduSkin.AdditionalAttributes;assembly=AduSkin"
    xmlns:AduSkin="clr-namespace:AduSkin.Controls;assembly=AduSkin"
    xmlns:Interactivity="clr-namespace:AduSkin.Interactivity;assembly=AduSkin"
    xmlns:local="clr-namespace:DotNetBuilder"
    Title=".NET Project Builder"
    Width="600"
    Height="900"
    MinWidth="600"
    MinHeight="600"
    WindowStartupLocation="CenterScreen">
    <Grid Background="{DynamicResource PanelBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition
                Height="200"
                MinHeight="200"
                MaxHeight="600" />
        </Grid.RowDefinitions>

        <!--  工具栏  -->
        <Border
            Padding="10"
            BorderBrush="#E0E0E0"
            BorderThickness="0,0,0,1"
            IsEnabled="{Binding IsBusy, Converter={StaticResource BooleanReverseConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!--  目录选择  -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <AduSkin:AduButton
                        Width="80"
                        Margin="0,0,15,0"
                        Command="{Binding SelectDirectoryCommand}"
                        Content="选择目录" />

                    <TextBlock
                        Margin="0,0,10,0"
                        VerticalAlignment="Center"
                        Foreground="#666"
                        Text="当前目录:" />
                    <AduSkin:AduTextBox
                        MaxWidth="300"
                        VerticalAlignment="Center"
                        BorderThickness="0"
                        IsReadOnly="True"
                        Text="{Binding SelectedPath}" />

                    <TextBlock
                        VerticalAlignment="Center"
                        Foreground="#888"
                        Text="{Binding Projects.Count, StringFormat=' ({0} 个项目)'}"
                        Visibility="{Binding Projects.Count, Converter={StaticResource BoolToVisibilityConverter}}" />
                </StackPanel>

                <!--  全选/取消全选  -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <AduSkin:AduButton
                        Margin="0,0,8,0"
                        Command="{Binding SelectAllCommand}"
                        Content="全选" />
                    <AduSkin:AduButton
                        Margin="0,0,8,0"
                        Command="{Binding SelectNoneCommand}"
                        Content="取消全选" />
                    <AduSkin:AduButton
                        Margin="0,0,8,0"
                        Command="{Binding RefreshStatusCommand}"
                        Content="刷新状态" />
                    <AduSkin:AduButton Command="{Binding SaveConfigCommand}" Content="保存" />
                </StackPanel>
            </Grid>
        </Border>

        <!--  主内容区域 - 项目列表  -->
        <Border
            Grid.Row="1"
            Margin="10"
            Padding="6"
            BorderBrush="{DynamicResource NormalBorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            IsEnabled="{Binding IsBusy, Converter={StaticResource BooleanReverseConverter}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!--  列表头部  -->
                <Border
                    Grid.Row="0"
                    Margin="0,0,0,10"
                    Padding="5,0,5,10"
                    BorderBrush="#E0E0E0"
                    BorderThickness="0,0,0,1">
                    <Grid Margin="20,0,30,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="144" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            Text="" />
                        <TextBlock
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            FontWeight="SemiBold"
                            Text="项目名称" />
                        <TextBlock
                            Grid.Column="2"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontWeight="SemiBold"
                            Text="类型" />
                        <TextBlock
                            Grid.Column="3"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontWeight="SemiBold"
                            Text="状态" />
                        <TextBlock
                            Grid.Column="4"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontWeight="SemiBold"
                            Text="操作" />
                    </Grid>
                </Border>

                <!--  项目列表  -->
                <AduSkin:AduScrollViewer
                    Grid.Row="1"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto">
                    <ScrollViewer.Resources>
                        <Style BasedOn="{StaticResource AduPathIconButton}" TargetType="AduSkin:AduPathIconButton">
                            <Setter Property="BorderThickness" Value="1" />
                            <Setter Property="Margin" Value="0,0,5,0" />
                            <Setter Property="Width" Value="24" />
                            <Setter Property="Height" Value="24" />
                            <Setter Property="AduAttach:BorderAttach.CornerRadius" Value="8" />
                            <Setter Property="AduAttach:PathBrushAttach.NormalPathBrush" Value="#0078D4" />
                            <Setter Property="AduAttach:PathDataAttach.Width" Value="8" />
                            <Setter Property="AduAttach:PathDataAttach.Margin" Value="0" />
                        </Style>
                    </ScrollViewer.Resources>
                    <ItemsControl Margin="4" ItemsSource="{Binding Projects}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <AduSkin:AduExpander
                                    x:Name="ItemBorder"
                                    Margin="0,0,0,8"
                                    Padding="12,4"
                                    BorderThickness="2"
                                    IsExpanded="{Binding IsExpanded}">
                                    <AduSkin:AduExpander.Header>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="40" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="80" />
                                                <ColumnDefinition Width="80" />
                                                <ColumnDefinition Width="150" />
                                            </Grid.ColumnDefinitions>

                                            <!--  勾选框  -->
                                            <AduSkin:AduCheckBox
                                                Grid.Column="0"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                IsChecked="{Binding IsSelected}" />

                                            <!--  项目信息  -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock
                                                    FontSize="14"
                                                    FontWeight="Medium"
                                                    Text="{Binding Name}" />
                                                <TextBlock
                                                    FontSize="11"
                                                    Foreground="#999"
                                                    Text="{Binding Path}"
                                                    TextTrimming="CharacterEllipsis"
                                                    ToolTip="{Binding Path}" />
                                            </StackPanel>

                                            <!--  类型标签  -->
                                            <Border
                                                Grid.Column="2"
                                                Padding="10,2"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Background="{Binding IsDotNetProject, Converter={StaticResource HasChangesToBrushConverter}}"
                                                CornerRadius="10">
                                                <TextBlock
                                                    FontSize="11"
                                                    Foreground="White"
                                                    Text="{Binding IsDotNetProject, Converter={StaticResource ProjectTypeConverter}}" />
                                            </Border>

                                            <!--  状态  -->
                                            <StackPanel
                                                Grid.Column="3"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center">
                                                <!--  同步中/构建中状态  -->
                                                <TextBlock
                                                    x:Name="txtSyncingStatus"
                                                    HorizontalAlignment="Center"
                                                    Foreground="{DynamicResource PrimaryBrush}"
                                                    Text="同步中..."
                                                    Visibility="Collapsed" />
                                                <TextBlock
                                                    x:Name="txtBuildingStatus"
                                                    HorizontalAlignment="Center"
                                                    Foreground="{DynamicResource PrimaryBrush}"
                                                    Text="构建中..."
                                                    Visibility="Collapsed" />
                                                <!--  正常状态显示更改数  -->
                                                <TextBlock
                                                    x:Name="txtChangesCount"
                                                    HorizontalAlignment="Center"
                                                    FontSize="12"
                                                    FontWeight="Bold"
                                                    Foreground="{Binding HasChanges, Converter={StaticResource HasChangesToBrushConverter}}"
                                                    Text="{Binding ChangesCount, Converter={StaticResource ChangesCountConverter}}" />
                                            </StackPanel>

                                            <!--  操作按钮  -->
                                            <StackPanel
                                                Grid.Column="4"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center"
                                                Orientation="Horizontal">
                                                <AduSkin:AduPathIconButton
                                                    Margin="0,0,5,0"
                                                    AduAttach:PathDataAttach.PathData="{DynamicResource Icon_Up}"
                                                    BorderThickness="1"
                                                    Command="{Binding DataContext.MoveUpCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    FontSize="12"
                                                    ToolTip="上移" />
                                                <AduSkin:AduPathIconButton
                                                    Margin="0,0,5,0"
                                                    AduAttach:PathDataAttach.PathData="{DynamicResource Icon_Down}"
                                                    BorderThickness="1"
                                                    Command="{Binding DataContext.MoveDownCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    FontSize="12"
                                                    ToolTip="下移" />
                                                <!--  单独同步按钮  -->
                                                <AduSkin:AduPathIconButton
                                                    Margin="0,0,5,0"
                                                    AduAttach:PathBrushAttach.NormalPathBrush="{DynamicResource NormalForeground}"
                                                    AduAttach:PathDataAttach.PathData="{DynamicResource Icon_Sync}"
                                                    AduAttach:PathDataAttach.Width="12"
                                                    Command="{Binding DataContext.SyncSingleCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    FontSize="10"
                                                    ToolTip="单独同步此项目" />
                                                <!--  单独构建按钮  -->
                                                <AduSkin:AduPathIconButton
                                                    Margin="0,0,5,0"
                                                    AduAttach:PathBrushAttach.NormalPathBrush="Green"
                                                    AduAttach:PathDataAttach.PathData="{DynamicResource Icon_Play}"
                                                    AduAttach:PathDataAttach.Width="9"
                                                    Command="{Binding DataContext.BuildSingleCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    FontSize="10"
                                                    ToolTip="单独构建此项目"
                                                    Visibility="{Binding IsDotNetProject, Converter={StaticResource BoolToVisibilityConverter}}" />
                                                <!--  移除项目按钮  -->
                                                <AduSkin:AduPathIconButton
                                                    AduAttach:PathBrushAttach.NormalPathBrush="#FF4444"
                                                    AduAttach:PathDataAttach.PathData="{DynamicResource Icon_Delete}"
                                                    AduAttach:PathDataAttach.Width="11"
                                                    Command="{Binding DataContext.RemoveProjectCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    FontSize="10"
                                                    ToolTip="移除此项目（保存后将不再加载）" />
                                            </StackPanel>
                                        </Grid>
                                    </AduSkin:AduExpander.Header>
                                    <AduSkin:AduExpander.Content>
                                        <StackPanel Margin="0,4,0,0">
                                            <!--  错误信息显示  -->
                                            <Border
                                                x:Name="ErrorPanel"
                                                Margin="0,0,0,10"
                                                Padding="10"
                                                Background="#FFF0F0"
                                                BorderBrush="#50FF4444"
                                                BorderThickness="1"
                                                CornerRadius="4"
                                                Visibility="Collapsed">
                                                <StackPanel>
                                                    <TextBlock
                                                        FontWeight="Bold"
                                                        Foreground="#CC0000"
                                                        Text="错误信息:" />
                                                    <AduSkin:AduTextBox
                                                        Height="Auto"
                                                        MaxHeight="200"
                                                        Margin="0,5,0,0"
                                                        BorderBrush="{DynamicResource ErrorBrush}"
                                                        FontSize="10"
                                                        Foreground="{DynamicResource ErrorBrush}"
                                                        IsReadOnly="True"
                                                        Text="{Binding ErrorMessage}"
                                                        TextWrapping="Wrap"
                                                        VerticalScrollBarVisibility="Auto" />
                                                </StackPanel>
                                            </Border>

                                            <UniformGrid Columns="3">
                                                <!--  MSBuild版本选择  -->
                                                <AduSkin:AduFormBox
                                                    Margin="0,0,10,0"
                                                    Header="MSBuild:"
                                                    Visibility="{Binding IsDotNetProject, Converter={StaticResource BoolToVisibilityConverter}}">
                                                    <AduSkin:AduComboBox ItemsSource="{Binding DataContext.MSBuildVersions, RelativeSource={RelativeSource AncestorType=Window}}" SelectedItem="{Binding SelectedMSBuildVersion}">
                                                        <AduSkin:AduComboBox.ItemTemplate>
                                                            <DataTemplate>
                                                                <TextBlock Text="{Binding DisplayName}" />
                                                            </DataTemplate>
                                                        </AduSkin:AduComboBox.ItemTemplate>
                                                    </AduSkin:AduComboBox>
                                                </AduSkin:AduFormBox>
                                                <!--  构建类型选择  -->
                                                <AduSkin:AduFormBox
                                                    Margin="0,0,10,0"
                                                    Header="Config:"
                                                    Visibility="{Binding IsDotNetProject, Converter={StaticResource BoolToVisibilityConverter}}">
                                                    <AduSkin:AduComboBox ItemsSource="{Binding DataContext.ConfigurationTypes, RelativeSource={RelativeSource AncestorType=Window}}" SelectedItem="{Binding Configuration}" />
                                                </AduSkin:AduFormBox>
                                                <!--  执行文件路径  -->
                                                <AduSkin:AduFormBox Header="ExecuteFile:">
                                                    <AduSkin:AduChooseBox Text="{Binding ExecuteFile}" />
                                                </AduSkin:AduFormBox>
                                            </UniformGrid>
                                            <Grid Margin="0,4,0,0">
                                                <TextBlock
                                                    x:Name="txtNotChange"
                                                    Margin="0,10"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Foreground="#777"
                                                    Text="暂无更改"
                                                    Visibility="Collapsed" />
                                                <!--  提交信息  -->
                                                <AduSkin:AduFormBox
                                                    x:Name="ChangePanel"
                                                    Margin="0,0,0,0"
                                                    AduAttach:HeaderAttach.VerticalAlignment="Top"
                                                    Header="Commit: "
                                                    Visibility="Collapsed">
                                                    <AduSkin:AduTextBox
                                                        Grid.Column="1"
                                                        Height="50"
                                                        Padding="4"
                                                        VerticalContentAlignment="Top"
                                                        Text="{Binding CommitMessage, UpdateSourceTrigger=PropertyChanged}"
                                                        ToolTip="输入该项目的提交信息" />
                                                </AduSkin:AduFormBox>
                                            </Grid>

                                        </StackPanel>
                                    </AduSkin:AduExpander.Content>
                                </AduSkin:AduExpander>
                                <DataTemplate.Triggers>
                                    <!--  有错误时红色边框并显示错误信息  -->
                                    <DataTrigger Binding="{Binding HasError}" Value="True">
                                        <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#FF4444" />
                                        <Setter TargetName="ErrorPanel" Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                    <!--  有更改时橙色边框  -->
                                    <DataTrigger Binding="{Binding HasChanges}" Value="True">
                                        <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#FFA500" />
                                        <Setter TargetName="ChangePanel" Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding HasChanges}" Value="False">
                                        <Setter TargetName="txtNotChange" Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                    <!--  同步中状态  -->
                                    <DataTrigger Binding="{Binding IsSyncing}" Value="True">
                                        <Setter TargetName="txtSyncingStatus" Property="Visibility" Value="Visible" />
                                        <Setter TargetName="txtChangesCount" Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                    <!--  构建中状态  -->
                                    <DataTrigger Binding="{Binding IsBuilding}" Value="True">
                                        <Setter TargetName="txtBuildingStatus" Property="Visibility" Value="Visible" />
                                        <Setter TargetName="txtChangesCount" Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </AduSkin:AduScrollViewer>

                <!--  空状态提示  -->
                <StackPanel
                    Grid.Row="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Visibility="{Binding Projects.Count, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="48"
                        Foreground="#CCC"
                        Text="&#xE8B7;" />
                    <TextBlock
                        Margin="0,10,0,0"
                        FontSize="16"
                        Foreground="#999"
                        Text="请选择包含Git项目的目录" />
                </StackPanel>
            </Grid>
        </Border>

        <AduSkin:AduGridSplitter Grid.Row="2" ResizeDirection="Rows" />
        <!--  底部区域  -->
        <Grid Grid.Row="3" Margin="20,10,20,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!--  右侧操作按钮  -->
            <StackPanel
                Margin="0,0,0,10"
                IsEnabled="{Binding IsBusy, Converter={StaticResource BooleanReverseConverter}}"
                Orientation="Horizontal">
                <AduSkin:AduFormBox Header="运行项目">
                    <AduSkin:AduComboBox
                        Width="120"
                        DisplayMemberPath="Path"
                        ItemsSource="{Binding Projects}"
                        SelectedItem="{Binding SelectedProject}" />
                </AduSkin:AduFormBox>
                <AduSkin:AduButton
                    Width="Auto"
                    Margin="10,0,0,0"
                    Padding="10,0"
                    Command="{Binding RunSelectedCommand}"
                    Content="运行程序" />
                <!--  主操作按钮  -->
                <AduSkin:AduButton
                    Width="Auto"
                    Margin="10,0,0,0"
                    Padding="10,0"
                    Command="{Binding SyncSelectedCommand}"
                    Content="Git 同步" />

                <AduSkin:AduButton
                    Width="Auto"
                    Margin="10,0,0,0"
                    Padding="10,0"
                    Command="{Binding BuildSelectedCommand}"
                    Content="MSBuild 构建" />

                <AduSkin:AduButton
                    Width="Auto"
                    Margin="10,0,0,0"
                    Padding="10,0"
                    Command="{Binding SaveConfigCommand}"
                    Content="保存配置" />
            </StackPanel>

            <!--  日志过滤选项  -->
            <StackPanel
                Grid.Row="1"
                Margin="0,0,0,10"
                IsEnabled="{Binding IsBusy, Converter={StaticResource BooleanReverseConverter}}"
                Orientation="Horizontal">
                <TextBlock
                    VerticalAlignment="Center"
                    Foreground="#666"
                    Text="日志过滤:" />
                <AduSkin:AduCheckBox
                    Margin="10,0,0,0"
                    AduAttach:PathBrushAttach.NormalPathBrush="{DynamicResource ErrorBrush}"
                    AduAttach:PathBrushAttach.SelectedPathBrush="{DynamicResource ErrorBrush}"
                    Content="错误"
                    Foreground="{DynamicResource ErrorBrush}"
                    IsChecked="{Binding ShowErrorLog}" />
                <AduSkin:AduCheckBox
                    Margin="10,0,0,0"
                    AduAttach:PathBrushAttach.NormalPathBrush="{DynamicResource WarnBrush}"
                    AduAttach:PathBrushAttach.SelectedPathBrush="{DynamicResource WarnBrush}"
                    Content="警告"
                    Foreground="{DynamicResource WarnBrush}"
                    IsChecked="{Binding ShowWarningLog}" />
                <AduSkin:AduCheckBox
                    Margin="10,0,0,0"
                    AduAttach:PathBrushAttach.NormalPathBrush="{DynamicResource InfoBrush}"
                    AduAttach:PathBrushAttach.SelectedPathBrush="{DynamicResource InfoBrush}"
                    Content="消息"
                    Foreground="{DynamicResource InfoBrush}"
                    IsChecked="{Binding ShowMessageLog}" />
                <AduSkin:AduCheckBox
                    Margin="10,0,0,0"
                    AduAttach:PathBrushAttach.NormalPathBrush="{DynamicResource SuccessBrush}"
                    AduAttach:PathBrushAttach.SelectedPathBrush="{DynamicResource SuccessBrush}"
                    Content="Git"
                    Foreground="{DynamicResource SuccessBrush}"
                    IsChecked="{Binding ShowGitLog}" />
                <AduSkin:AduCheckBox
                    Margin="10,0,0,0"
                    AduAttach:PathBrushAttach.NormalPathBrush="{DynamicResource StringPinBrush}"
                    AduAttach:PathBrushAttach.SelectedPathBrush="{DynamicResource StringPinBrush}"
                    Content="Build"
                    Foreground="{DynamicResource StringPinBrush}"
                    IsChecked="{Binding ShowBuildLog}"
                    ToolTip="MSBuild编译详细输出（文件路径等），默认不显示" />
            </StackPanel>

            <!--  日志输出  -->
            <AduSkin:AduGroupBox Grid.Row="2" VerticalContentAlignment="Stretch">
                <AduSkin:AduGroupBox.Header>
                    <Grid>
                        <TextBlock VerticalAlignment="Center" Text="输出日志" />
                        <AduSkin:AduButton
                            Width="40"
                            Height="Auto"
                            HorizontalAlignment="Right"
                            Background="Transparent"
                            BorderThickness="0"
                            Command="{Binding ClearLogCommand}"
                            Content="清空"
                            FontSize="11"
                            Foreground="{DynamicResource PrimaryBrush}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource BooleanReverseConverter}}" />
                    </Grid>
                </AduSkin:AduGroupBox.Header>

                <AduSkin:AduTextBox
                    Height="Auto"
                    VerticalAlignment="Stretch"
                    VerticalContentAlignment="Top"
                    AduAttach:BorderAttach.CornerRadius="0,0,6,6"
                    BorderThickness="0"
                    FontSize="10"
                    IsAutoScrollToBottom="True"
                    IsReadOnly="True"
                    Text="{Binding LogOutput}"
                    TextWrapping="Wrap"
                    VerticalScrollBarVisibility="Auto" />
            </AduSkin:AduGroupBox>

        </Grid>

        <!--  加载中遮罩  -->
        <Border Grid.RowSpan="2" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <AduSkin:AduLoading
                    Width="100"
                    Height="100"
                    IsActived="{Binding IsBusy}" />
                <TextBlock
                    Margin="0,15,0,0"
                    HorizontalAlignment="Center"
                    FontSize="14"
                    Foreground="White"
                    Text="处理中..." />
            </StackPanel>
        </Border>
    </Grid>
</AduSkin:AduWindow>
