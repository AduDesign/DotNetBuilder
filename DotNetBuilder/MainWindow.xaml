<AduSkin:AduWindow
    x:Class="DotNetBuilder.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:AduAttach="clr-namespace:AduSkin.AdditionalAttributes;assembly=AduSkin"
    xmlns:AduSkin="clr-namespace:AduSkin.Controls;assembly=AduSkin"
    xmlns:Interactivity="clr-namespace:AduSkin.Interactivity;assembly=AduSkin"
    xmlns:local="clr-namespace:DotNetBuilder"
    Title=".NET 项目管理器"
    Width="1000"
    Height="700"
    MinWidth="800"
    MinHeight="600"
    WindowStartupLocation="CenterScreen">

    <Grid Background="#F5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="200" />
        </Grid.RowDefinitions>

        <!--  顶部标题栏  -->
        <Border
            Grid.Row="0"
            Padding="20,15"
            Background="White"
            BorderBrush="#E0E0E0"
            BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <Path
                        Width="28"
                        Margin="0,0,10,0"
                        VerticalAlignment="Center"
                        Data="{DynamicResource Icon_Build}"
                        Fill="#0078D4" />
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="20"
                        FontWeight="SemiBold"
                        Foreground="#333"
                        Text=".NET 项目管理器" />
                </StackPanel>

                <!--  全选/取消全选  -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <AduSkin:AduButton
                        Margin="0,0,8,0"
                        Command="{Binding SelectAllCommand}"
                        Content="全选" />
                    <AduSkin:AduButton
                        Margin="0,0,8,0"
                        Command="{Binding SelectNoneCommand}"
                        Content="取消全选" />
                    <AduSkin:AduButton Command="{Binding RefreshStatusCommand}" Content="刷新状态" />
                </StackPanel>
            </Grid>
        </Border>

        <!--  工具栏  -->
        <Border
            Grid.Row="1"
            Padding="20,15"
            Background="White"
            BorderBrush="#E0E0E0"
            BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!--  目录选择  -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <AduSkin:AduButton
                        Margin="0,0,15,0"
                        Command="{Binding SelectDirectoryCommand}"
                        Content="选择目录" />

                    <TextBlock
                        Margin="0,0,10,0"
                        VerticalAlignment="Center"
                        Foreground="#666"
                        Text="当前目录:" />
                    <AduSkin:AduTextBox
                        MaxWidth="300"
                        VerticalAlignment="Center"
                        BorderThickness="0"
                        Foreground="#333"
                        IsReadOnly="True"
                        Text="{Binding SelectedPath}" />

                    <TextBlock
                        VerticalAlignment="Center"
                        Foreground="#888"
                        Text="{Binding Projects.Count, StringFormat=' ({0} 个项目)'}"
                        Visibility="{Binding Projects.Count, Converter={StaticResource BoolToVisibilityConverter}}" />
                </StackPanel>
            </Grid>
        </Border>

        <!--  主内容区域 - 项目列表  -->
        <Border
            Grid.Row="2"
            Margin="20,15"
            Padding="15"
            Background="White"
            BorderBrush="{DynamicResource NormalBorderBrush}"
            BorderThickness="1"
            CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!--  列表头部  -->
                <Border
                    Grid.Row="0"
                    Margin="0,0,0,10"
                    Padding="5,0,5,10"
                    BorderBrush="#E0E0E0"
                    BorderThickness="0,0,0,1">
                    <Grid Margin="20,0,30,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="120" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            Text="" />
                        <TextBlock
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            FontWeight="SemiBold"
                            Foreground="#333"
                            Text="项目名称" />
                        <TextBlock
                            Grid.Column="2"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontWeight="SemiBold"
                            Foreground="#333"
                            Text="类型" />
                        <TextBlock
                            Grid.Column="3"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontWeight="SemiBold"
                            Foreground="#333"
                            Text="状态" />
                        <TextBlock
                            Grid.Column="4"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontWeight="SemiBold"
                            Foreground="#333"
                            Text="操作" />
                    </Grid>
                </Border>

                <!--  项目列表  -->
                <AduSkin:AduScrollViewer
                    Grid.Row="1"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto">
                    <ItemsControl Margin="10,0" ItemsSource="{Binding Projects}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <AduSkin:AduExpander
                                    x:Name="ItemBorder"
                                    Margin="0,0,0,8"
                                    Padding="12,10"
                                    BorderThickness="2"
                                    IsExpanded="{Binding IsExpanded}">
                                    <AduSkin:AduExpander.Header>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="40" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="80" />
                                                <ColumnDefinition Width="80" />
                                                <ColumnDefinition Width="120" />
                                            </Grid.ColumnDefinitions>

                                            <!--  勾选框  -->
                                            <AduSkin:AduCheckBox
                                                Grid.Column="0"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                IsChecked="{Binding IsSelected}" />

                                            <!--  项目信息  -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock
                                                    FontSize="14"
                                                    FontWeight="Medium"
                                                    Foreground="#333"
                                                    Text="{Binding Name}" />
                                                <TextBlock
                                                    FontSize="11"
                                                    Foreground="#999"
                                                    Text="{Binding Path}"
                                                    TextTrimming="CharacterEllipsis"
                                                    ToolTip="{Binding Path}" />
                                            </StackPanel>

                                            <!--  类型标签  -->
                                            <Border
                                                Grid.Column="2"
                                                Padding="10,2"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Background="{Binding IsDotNetProject, Converter={StaticResource HasChangesToBrushConverter}}"
                                                CornerRadius="10">
                                                <TextBlock
                                                    FontSize="11"
                                                    Foreground="White"
                                                    Text="{Binding IsDotNetProject, Converter={StaticResource ProjectTypeConverter}}" />
                                            </Border>

                                            <!--  状态  -->
                                            <StackPanel
                                                Grid.Column="3"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center">
                                                <TextBlock
                                                    HorizontalAlignment="Center"
                                                    FontSize="12"
                                                    FontWeight="Bold"
                                                    Foreground="{Binding HasChanges, Converter={StaticResource HasChangesToBrushConverter}}"
                                                    Text="{Binding ChangesCount, Converter={StaticResource ChangesCountConverter}}" />
                                            </StackPanel>

                                            <!--  排序按钮  -->
                                            <StackPanel
                                                Grid.Column="4"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Orientation="Horizontal">
                                                <AduSkin:AduPathIconButton
                                                    Margin="0,0,5,0"
                                                    AduAttach:BorderAttach.CornerRadius="10"
                                                    AduAttach:PathBrushAttach.NormalPathBrush="{DynamicResource NormalForeground}"
                                                    AduAttach:PathDataAttach.PathData="{DynamicResource Icon_Up}"
                                                    AduAttach:PathDataAttach.Width="8"
                                                    BorderThickness="1"
                                                    Command="{Binding DataContext.MoveUpCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    FontSize="12"
                                                    ToolTip="上移" />
                                                <AduSkin:AduPathIconButton
                                                    AduAttach:BorderAttach.CornerRadius="10"
                                                    AduAttach:PathBrushAttach.NormalPathBrush="{DynamicResource NormalForeground}"
                                                    AduAttach:PathDataAttach.PathData="{DynamicResource Icon_Down}"
                                                    AduAttach:PathDataAttach.Width="8"
                                                    BorderThickness="1"
                                                    Command="{Binding DataContext.MoveDownCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    FontSize="12"
                                                    ToolTip="下移" />
                                            </StackPanel>
                                        </Grid>
                                    </AduSkin:AduExpander.Header>
                                    <AduSkin:AduExpander.Content>
                                        <StackPanel Margin="0,10,0,0">
                                            <!--  MSBuild版本选择  -->
                                            <AduSkin:AduFormBox Header="MSBuild:">
                                                <AduSkin:AduComboBox ItemsSource="{Binding DataContext.MSBuildVersions, RelativeSource={RelativeSource AncestorType=Window}}" SelectedItem="{Binding SelectedMSBuildVersion}">
                                                    <AduSkin:AduComboBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding DisplayName}" />
                                                        </DataTemplate>
                                                    </AduSkin:AduComboBox.ItemTemplate>
                                                </AduSkin:AduComboBox>
                                            </AduSkin:AduFormBox>
                                            <Grid Margin="0,10,0,0">
                                                <TextBlock
                                                    x:Name="txtNotChange"
                                                    Margin="0,10"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Foreground="#777"
                                                    Text="暂无更改"
                                                    Visibility="Collapsed" />
                                                <!--  提交信息  -->
                                                <AduSkin:AduFormBox
                                                    x:Name="ChangePanel"
                                                    Margin="0,0,0,0"
                                                    AduAttach:HeaderAttach.VerticalAlignment="Top"
                                                    Header="提交信息:"
                                                    Visibility="Collapsed">
                                                    <AduSkin:AduTextBox
                                                        Grid.Column="1"
                                                        Height="50"
                                                        Text="{Binding CommitMessage, UpdateSourceTrigger=PropertyChanged}"
                                                        ToolTip="输入该项目的提交信息" />
                                                </AduSkin:AduFormBox>
                                            </Grid>

                                        </StackPanel>
                                    </AduSkin:AduExpander.Content>
                                </AduSkin:AduExpander>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding HasChanges}" Value="True">
                                        <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#FFA500" />
                                        <Setter TargetName="ChangePanel" Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding HasChanges}" Value="False">
                                        <Setter TargetName="txtNotChange" Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </AduSkin:AduScrollViewer>

                <!--  空状态提示  -->
                <StackPanel
                    Grid.Row="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Visibility="{Binding Projects.Count, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="48"
                        Foreground="#CCC"
                        Text="&#xE8B7;" />
                    <TextBlock
                        Margin="0,10,0,0"
                        FontSize="16"
                        Foreground="#999"
                        Text="请选择包含Git项目的目录" />
                </StackPanel>
            </Grid>
        </Border>

        <!--  底部区域  -->
        <Grid Grid.Row="3" Margin="20,0,20,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!--  日志输出  -->
            <Border
                Grid.Column="0"
                Padding="15"
                BorderBrush="{DynamicResource NormalBorderBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock FontWeight="SemiBold" Text="输出日志" />
                        <AduSkin:AduButton
                            Padding="10,3"
                            HorizontalAlignment="Right"
                            Command="{Binding ClearLogCommand}"
                            Content="清空"
                            FontSize="11" />
                    </Grid>

                    <AduSkin:AduScrollViewer
                        Grid.Row="1"
                        HorizontalScrollBarVisibility="Auto"
                        VerticalScrollBarVisibility="Auto">
                        <TextBlock
                            FontFamily="Consolas"
                            FontSize="12"
                            Text="{Binding LogOutput}"
                            TextWrapping="Wrap" />
                    </AduSkin:AduScrollViewer>
                </Grid>
            </Border>

            <!--  右侧操作按钮  -->
            <StackPanel
                Grid.Column="1"
                Width="150"
                Margin="15,0,0,0">
                <AduSkin:AduComboBox
                    Margin="0,0,0,10"
                    ItemsSource="{Binding Executables}"
                    SelectedItem="{Binding SelectedExecutable}" />
                <!--  主操作按钮  -->
                <AduSkin:AduButton
                    Width="Auto"
                    Margin="0,0,0,10"
                    Command="{Binding SyncSelectedCommand}"
                    Content="Git 同步" />

                <AduSkin:AduButton
                    Width="Auto"
                    Margin="0,0,0,10"
                    Command="{Binding BuildSelectedCommand}"
                    Content="MSBuild 构建" />

                <AduSkin:AduButton
                    Width="Auto"
                    Command="{Binding RunSelectedCommand}"
                    Content="运行程序" />
            </StackPanel>
        </Grid>

        <!--  加载中遮罩  -->
        <Border
            Grid.RowSpan="4"
            Background="#80000000"
            Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <AduSkin:AduLoading
                    Width="100"
                    Height="100"
                    IsActived="{Binding IsBusy}" />
                <TextBlock
                    Margin="0,15,0,0"
                    HorizontalAlignment="Center"
                    FontSize="14"
                    Foreground="White"
                    Text="处理中..." />
            </StackPanel>
        </Border>
    </Grid>
</AduSkin:AduWindow>
