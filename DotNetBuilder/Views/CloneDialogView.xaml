<UserControl
    x:Class="DotNetBuilder.Views.CloneDialogView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:AduAttach="clr-namespace:AduSkin.AdditionalAttributes;assembly=AduSkin"
    xmlns:AduSkin="clr-namespace:AduSkin.Controls;assembly=AduSkin">

    <Border Background="#80000000" Visibility="{Binding ShowDialog, Converter={StaticResource BoolToVisibilityConverter}}">
        <Border
            Width="500"
            Padding="20"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="{DynamicResource WindowBackground}"
            BorderBrush="{DynamicResource NormalBorderBrush}"
            BorderThickness="1"
            CornerRadius="8">
            <StackPanel>
                <TextBlock
                    FontSize="18"
                    FontWeight="Bold"
                    Foreground="{DynamicResource PrimaryBrush}"
                    Text="克隆 Git 仓库" />

                <AduSkin:AduFormBox Margin="0,15,0,5" Header="仓库 URL">
                    <AduSkin:AduTextBox
                        Height="30"
                        IsEnabled="{Binding IsCloning, Converter={StaticResource InverseBoolConverter}}"
                        Text="{Binding RepositoryUrl, UpdateSourceTrigger=PropertyChanged}" />
                </AduSkin:AduFormBox>

                <TextBlock
                    Margin="0,5,0,0"
                    FontSize="11"
                    Foreground="#888"
                    Text="支持 GitHub、GitLab、Gitee 等 Git 仓库地址"
                    TextWrapping="Wrap" />

                <AduSkin:AduFormBox Margin="0,15,0,5" Header="本地存储目录">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <AduSkin:AduTextBox
                            Height="30"
                            VerticalAlignment="Center"
                            IsEnabled="{Binding IsCloning, Converter={StaticResource InverseBoolConverter}}"
                            Text="{Binding LocalDirectory, UpdateSourceTrigger=PropertyChanged}" />
                        <AduSkin:AduButton
                            Grid.Column="1"
                            Margin="8,0,0,0"
                            Command="{Binding BrowseCommand}"
                            Content="浏览"
                            IsEnabled="{Binding IsCloning, Converter={StaticResource InverseBoolConverter}}" />
                    </Grid>
                </AduSkin:AduFormBox>

                <TextBlock
                    Margin="0,5,0,0"
                    FontSize="11"
                    Foreground="#888"
                    Text="选择克隆仓库存放的目录" />

                <!-- 状态消息 -->
                <Border
                    Margin="0,15,0,0"
                    Padding="10"
                    Background="#F5F5F5"
                    CornerRadius="4"
                    Visibility="{Binding CloneStatusMessage, Converter={StaticResource StringToVisibilityConverter}}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <AduSkin:AduProgressRing
                                Width="16"
                                Height="16"
                                Margin="0,0,8,0"
                                IsActive="{Binding IsCloning}"
                                Visibility="{Binding IsCloning, Converter={StaticResource BoolToVisibilityConverter}}" />
                            <TextBlock
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource PrimaryBrush}"
                                Text="{Binding CloneStatusMessage}" />
                        </StackPanel>
                        <TextBlock
                            Margin="0,5,0,0"
                            FontSize="11"
                            Foreground="#E53935"
                            Text="{Binding LastErrorMessage}"
                            TextWrapping="Wrap"
                            Visibility="{Binding LastErrorMessage, Converter={StaticResource StringToVisibilityConverter}}" />
                    </StackPanel>
                </Border>

                <StackPanel
                    Margin="0,15,0,0"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
                    <!-- 克隆中显示取消按钮 -->
                    <AduSkin:AduButton
                        Width="80"
                        Margin="0,0,10,0"
                        Background="#E53935"
                        Command="{Binding CancelCloneCommand}"
                        Content="取消"
                        Foreground="White"
                        Visibility="{Binding IsCloning, Converter={StaticResource BoolToVisibilityConverter}}" />

                    <!-- 克隆完成后显示关闭按钮 -->
                    <AduSkin:AduButton
                        Width="80"
                        Margin="0,0,10,0"
                        Command="{Binding CloseCommand}"
                        Content="关闭"
                        Visibility="{Binding IsCloning, Converter={StaticResource InverseBoolVisibilityConverter}}" />

                    <!-- 默认显示取消/克隆按钮 -->
                    <AduSkin:AduButton
                        Width="80"
                        Command="{Binding CloneCommand}"
                        Content="{Binding IsCloning, Converter={StaticResource BoolToTextCloneConverter}}"
                        IsEnabled="{Binding CanClone}" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Border>
</UserControl>
