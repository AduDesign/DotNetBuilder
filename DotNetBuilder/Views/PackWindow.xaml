<Window
    x:Class="DotNetBuilder.Views.PackWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:AduAttach="clr-namespace:AduSkin.AdditionalAttributes;assembly=AduSkin"
    xmlns:AduSkin="clr-namespace:AduSkin.Controls;assembly=AduSkin"
    xmlns:converters="clr-namespace:DotNetBuilder.Converters"
    Title="打包项目"
    Width="650"
    Height="550"
    Background="{DynamicResource WindowBackground}"
    WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
        <converters:IsDirectoryToIconConverter x:Key="IsDirectoryToIconConverter" />
        <converters:IsDirectoryToBrushConverter x:Key="IsDirectoryToBrushConverter" />
        <converters:BoolToPackButtonTextConverter x:Key="BoolToPackButtonTextConverter" />
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <!--  文件夹图标  -->
        <Geometry x:Key="FolderIcon">M10,4H4C2.9,4 2,4.9 2,6V18C2,19.1 2.9,20 4,20H20C21.1,20 22,19.1 22,18V8C22,6.9 21.1,6 20,6H12L10,4Z</Geometry>
        <!--  文件图标  -->
        <Geometry x:Key="FileIcon">M14,2H6C4.9,2 4,2.9 4,4V20C4,21.1 4.9,22 6,22H18C19.1,22 20,21.1 20,20V8L14,2M18,20H6V4H13V9H18V20Z</Geometry>
    </Window.Resources>
    <Grid>
        <Grid Margin="15,5,15,15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  头部信息  -->
            <AduSkin:AduEditableTextBlock
                Margin="0,0,0,4"
                HorizontalAlignment="Left"
                Foreground="#666"
                Text="{Binding SourcePath}"
                TextTrimming="CharacterEllipsis" />

            <!--  文件选择区域  -->
            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!--  选择按钮  -->
                <StackPanel
                    Grid.Row="0"
                    Margin="0,0,0,8"
                    Orientation="Horizontal">
                    <AduSkin:AduButton
                        Width="70"
                        Margin="0,0,8,0"
                        Command="{Binding SelectAllCommand}"
                        Content="全选" />
                    <AduSkin:AduButton
                        Width="70"
                        Command="{Binding UnselectAllCommand}"
                        Content="取消" />
                    <TextBlock
                        Margin="15,0,0,0"
                        VerticalAlignment="Center"
                        Foreground="#888"
                        Text="{Binding StatusMessage}" />
                </StackPanel>

                <!--  文件树  -->
                <AduSkin:AduTreeView
                    x:Name="FileTree"
                    Grid.Row="1"
                    Padding="6"
                    BorderThickness="1"
                    ItemsSource="{Binding FileNodes}">
                    <AduSkin:AduTreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                            <StackPanel Orientation="Horizontal">
                                <AduSkin:AduCheckBox
                                    VerticalAlignment="Center"
                                    Content=""
                                    IsChecked="{Binding IsChecked}" />
                                <Path
                                    Width="16"
                                    Height="16"
                                    VerticalAlignment="Center"
                                    Data="{Binding IsDirectory, Converter={StaticResource IsDirectoryToIconConverter}}"
                                    Fill="{Binding IsDirectory, Converter={StaticResource IsDirectoryToBrushConverter}}"
                                    Stretch="Uniform" />
                                <TextBlock
                                    Margin="4,0,0,0"
                                    VerticalAlignment="Center"
                                    Text="{Binding Name}" />
                            </StackPanel>
                        </HierarchicalDataTemplate>
                    </AduSkin:AduTreeView.ItemTemplate>
                </AduSkin:AduTreeView>
            </Grid>

            <!--  输出和密码设置  -->
            <Grid Grid.Row="2" Margin="0,15,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition />
                    <RowDefinition />
                </Grid.RowDefinitions>
                <!--  输出路径  -->
                <AduSkin:AduFormBox
                    Grid.Column="0"
                    AduAttach:HeaderAttach.Width="50"
                    Header="输出路径">
                    <AduSkin:AduChooseBox
                        Height="30"
                        ChooseType="SingleFile"
                        Text="{Binding OutputPath, UpdateSourceTrigger=PropertyChanged}" />
                </AduSkin:AduFormBox>

                <Grid Grid.Row="1" Margin="0,10,0,0">
                    <!--  密码设置  -->
                    <AduSkin:AduFormBox
                        Margin="0,0,10,0"
                        VerticalAlignment="Center"
                        AduAttach:HeaderAttach.Width="50"
                        Header="密码">
                        <StackPanel Orientation="Horizontal">
                            <PasswordBox
                                x:Name="PasswordBox"
                                Width="200"
                                Height="30"
                                IsEnabled="{Binding UsePassword}" />
                            <AduSkin:AduCheckBox
                                Grid.Row="0"
                                Grid.Column="0"
                                Margin="10,0,0,0"
                                Content="使用密码保护"
                                IsChecked="{Binding UsePassword}" />
                        </StackPanel>
                    </AduSkin:AduFormBox>

                    <StackPanel
                        Grid.Row="3"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal">
                        <AduSkin:AduButton
                            Width="80"
                            Margin="0,0,10,0"
                            Command="{Binding CancelCommand}"
                            Content="取消" />
                        <AduSkin:AduButton
                            Width="100"
                            Background="{DynamicResource PrimaryBrush}"
                            Command="{Binding PackCommand}"
                            Content="{Binding IsPacking, Converter={StaticResource BoolToPackButtonTextConverter}}"
                            Foreground="White"
                            IsEnabled="{Binding CanPack}" />
                    </StackPanel>
                </Grid>
            </Grid>

            <!--  按钮区域  -->

        </Grid>

        <!--  加载指示  -->
        <Border Background="#40000000" Visibility="{Binding IsPacking, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <AduSkin:AduProgressRing
                    Width="100"
                    Height="100"
                    IsActive="True" />
                <TextBlock
                    Margin="0,10,0,0"
                    HorizontalAlignment="Center"
                    FontSize="14"
                    Text="{Binding StatusMessage}" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
