<UserControl
	x:Class="DotNetBuilder.Views.OutputView"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:AduAttach="clr-namespace:AduSkin.AdditionalAttributes;assembly=AduSkin"
	xmlns:AduSkin="clr-namespace:AduSkin.Controls;assembly=AduSkin">

	<Grid Margin="10">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>
		<!--  日志过滤选项  -->
		<StackPanel IsEnabled="{Binding IsEnabled, Converter={StaticResource BooleanReverseConverter}}" Orientation="Horizontal">
			<TextBlock
				VerticalAlignment="Center"
				Foreground="#666"
				Text="日志过滤:" />
			<AduSkin:AduCheckBox
				Margin="10,0,0,0"
				AduAttach:PathBrushAttach.NormalPathBrush="{DynamicResource ErrorBrush}"
				AduAttach:PathBrushAttach.SelectedPathBrush="{DynamicResource ErrorBrush}"
				Content="错误"
				Foreground="{DynamicResource ErrorBrush}"
				IsChecked="{Binding ShowErrorLog}" />
			<AduSkin:AduCheckBox
				Margin="10,0,0,0"
				AduAttach:PathBrushAttach.NormalPathBrush="{DynamicResource WarnBrush}"
				AduAttach:PathBrushAttach.SelectedPathBrush="{DynamicResource WarnBrush}"
				Content="警告"
				Foreground="{DynamicResource WarnBrush}"
				IsChecked="{Binding ShowWarningLog}" />
			<AduSkin:AduCheckBox
				Margin="10,0,0,0"
				AduAttach:PathBrushAttach.NormalPathBrush="{DynamicResource InfoBrush}"
				AduAttach:PathBrushAttach.SelectedPathBrush="{DynamicResource InfoBrush}"
				Content="消息"
				Foreground="{DynamicResource InfoBrush}"
				IsChecked="{Binding ShowMessageLog}" />
			<AduSkin:AduCheckBox
				Margin="10,0,0,0"
				AduAttach:PathBrushAttach.NormalPathBrush="{DynamicResource SuccessBrush}"
				AduAttach:PathBrushAttach.SelectedPathBrush="{DynamicResource SuccessBrush}"
				Content="Git"
				Foreground="{DynamicResource SuccessBrush}"
				IsChecked="{Binding ShowGitLog}" />
			<AduSkin:AduCheckBox
				Margin="10,0,0,0"
				AduAttach:PathBrushAttach.NormalPathBrush="{DynamicResource StringPinBrush}"
				AduAttach:PathBrushAttach.SelectedPathBrush="{DynamicResource StringPinBrush}"
				Content="Build"
				Foreground="{DynamicResource StringPinBrush}"
				IsChecked="{Binding ShowBuildLog}"
				ToolTip="MSBuild编译详细输出（文件路径等），默认不显示" />
		</StackPanel>

		<!--  日志输出  -->
		<AduSkin:AduGroupBox
			Grid.Row="1"
			Margin="0,10,0,0"
			VerticalContentAlignment="Stretch">
			<AduSkin:AduGroupBox.Header>
				<Grid>
					<TextBlock VerticalAlignment="Center" Text="输出日志" />
					<AduSkin:AduButton
						Width="40"
						Height="Auto"
						HorizontalAlignment="Right"
						Background="Transparent"
						BorderThickness="0"
						Command="{Binding ClearLogCommand}"
						Content="清空"
						FontSize="11"
						Foreground="{DynamicResource PrimaryBrush}"
						IsEnabled="{Binding IsEnabled, Converter={StaticResource BooleanReverseConverter}}" />
				</Grid>
			</AduSkin:AduGroupBox.Header>

			<AduSkin:AduTextBox
				Height="Auto"
				VerticalAlignment="Stretch"
				VerticalContentAlignment="Top"
				AduAttach:BorderAttach.CornerRadius="0,0,6,6"
				BorderThickness="0"
				FontSize="10"
				IsAutoScrollToBottom="True"
				IsReadOnly="True"
				MultipleLine="True"
				Text="{Binding LogOutput}"
				TextWrapping="Wrap"
				VerticalScrollBarVisibility="Auto" />
		</AduSkin:AduGroupBox>
	</Grid>
</UserControl>
