<UserControl
    x:Class="DotNetBuilder.Views.ProjectListView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:AduAttach="clr-namespace:AduSkin.AdditionalAttributes;assembly=AduSkin"
    xmlns:AduSkin="clr-namespace:AduSkin.Controls;assembly=AduSkin">

    <Border
        Margin="10"
        Padding="6"
        BorderBrush="{DynamicResource NormalBorderBrush}"
        BorderThickness="1"
        CornerRadius="8"
        IsEnabled="{Binding IsEnabled}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  列表头部  -->
            <Border
                Grid.Row="0"
                Margin="0,0,0,0"
                Padding="5,0,5,10"
                BorderBrush="#E0E0E0"
                BorderThickness="0,0,0,1">
                <Grid Margin="10,6,30,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="30" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="110" />
                    </Grid.ColumnDefinitions>

                    <AduSkin:AduCheckBox
                        Content=""
                        IsChecked="{Binding IsSelectedAll}"
                        IsThreeState="True" />
                    <TextBlock
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        FontWeight="SemiBold"
                        Text="项目名称" />
                    <TextBlock
                        Grid.Column="2"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontWeight="SemiBold"
                        Text="类型" />
                    <TextBlock
                        Grid.Column="3"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontWeight="SemiBold"
                        Text="状态" />
                    <TextBlock
                        Grid.Column="4"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontWeight="SemiBold"
                        Text="操作" />
                </Grid>
            </Border>

            <!--  项目列表  -->
            <AduSkin:AduListBox
                Grid.Row="1"
                Padding="0,4"
                AduAttach:BackgroundAttach.MouseOverBackground="Transparent"
                AduAttach:BackgroundAttach.SelectedBackground="{DynamicResource PrimaryBrush05}"
                ItemsSource="{Binding Projects}"
                SelectedItem="{Binding SelectedProject}">
                <AduSkin:AduListBox.Resources>
                    <Style BasedOn="{StaticResource AduPathIconButton}" TargetType="AduSkin:AduPathIconButton">
                        <Setter Property="BorderThickness" Value="1" />
                        <Setter Property="Margin" Value="0,0,5,0" />
                        <Setter Property="Width" Value="24" />
                        <Setter Property="Height" Value="24" />
                        <Setter Property="AduAttach:BorderAttach.CornerRadius" Value="8" />
                        <Setter Property="AduAttach:PathBrushAttach.NormalPathBrush" Value="{DynamicResource Primarybrush}" />
                        <Setter Property="AduAttach:PathDataAttach.Width" Value="8" />
                        <Setter Property="AduAttach:PathDataAttach.Margin" Value="0" />
                    </Style>
                </AduSkin:AduListBox.Resources>
                <AduSkin:AduListBox.ItemContainerStyle>
                    <Style BasedOn="{StaticResource AduListBoxItem}" TargetType="AduSkin:AduListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="AduAttach:BorderAttach.CornerRadius" Value="8" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="Padding" Value="0" />
                    </Style>
                </AduSkin:AduListBox.ItemContainerStyle>
                <AduSkin:AduListBox.ContextMenu>
                    <AduSkin:AduContextMenu>
                        <AduSkin:AduMenuItem
                            Command="{Binding OpenFolderCommand}"
                            CommandParameter="{Binding SelectedItem}"
                            Header="打开目录" />
                        <AduSkin:AduMenuItem
                            Command="{Binding OpenVSCommand}"
                            CommandParameter="{Binding SelectedItem}"
                            Header="VisualStudio 打开" />
                        <AduSkin:AduMenuItem
                            Command="{Binding OpenVSCodeCommand}"
                            CommandParameter="{Binding SelectedItem}"
                            Header="VisualStudio Code 打开" />
                        <Separator />
                        <AduSkin:AduMenuItem
                            Command="{Binding BuildSingleCommand}"
                            CommandParameter="{Binding SelectedItem}"
                            Header="构建" />
                        <AduSkin:AduMenuItem
                            Command="{Binding RunSelectedCommand}"
                            CommandParameter="{Binding SelectedItem}"
                            Header="运行" />
                        <Separator />
                        <AduSkin:AduMenuItem
                            Command="{Binding RemoveProjectCommand}"
                            CommandParameter="{Binding SelectedItem}"
                            Header="删除" />
                    </AduSkin:AduContextMenu>
                </AduSkin:AduListBox.ContextMenu>
                <AduSkin:AduListBox.ItemTemplate>
                    <DataTemplate>
                        <AduSkin:AduExpander
                            x:Name="ItemBorder"
                            Padding="8,4"
                            Background="Transparent"
                            BorderThickness="2"
                            IsExpanded="{Binding IsExpanded}">
                            <AduSkin:AduExpander.Header>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="30" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="120" />
                                    </Grid.ColumnDefinitions>

                                    <!--  勾选框  -->
                                    <AduSkin:AduCheckBox
                                        Grid.Column="0"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Content=""
                                        IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                    <!--  项目信息  -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock
                                            FontSize="14"
                                            FontWeight="Medium"
                                            Text="{Binding Name}" />
                                        <TextBlock
                                            FontSize="11"
                                            Foreground="#999"
                                            Text="{Binding Path}"
                                            TextTrimming="CharacterEllipsis"
                                            ToolTip="{Binding Path}" />
                                    </StackPanel>

                                    <!--  类型标签  -->
                                    <Border
                                        Grid.Column="2"
                                        Padding="4,1"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Background="{Binding IsDotNetProject, Converter={StaticResource HasChangesToBrushConverter}}"
                                        CornerRadius="4">
                                        <TextBlock
                                            FontSize="10"
                                            Foreground="White"
                                            Text="{Binding IsDotNetProject, Converter={StaticResource ProjectTypeConverter}}" />
                                    </Border>

                                    <!--  状态  -->
                                    <StackPanel
                                        Grid.Column="3"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                        <TextBlock
                                            x:Name="txtSyncingStatus"
                                            HorizontalAlignment="Center"
                                            FontSize="12"
                                            Foreground="{DynamicResource PrimaryBrush}"
                                            Text="同步中..."
                                            Visibility="Collapsed" />
                                        <TextBlock
                                            x:Name="txtBuildingStatus"
                                            HorizontalAlignment="Center"
                                            FontSize="12"
                                            Foreground="{DynamicResource PrimaryBrush}"
                                            Text="构建中..."
                                            Visibility="Collapsed" />
                                        <TextBlock
                                            x:Name="txtChangesCount"
                                            HorizontalAlignment="Center"
                                            FontSize="12"
                                            FontWeight="Bold"
                                            Foreground="{Binding HasChanges, Converter={StaticResource HasChangesToBrushConverter}}"
                                            Text="{Binding ChangesCount, Converter={StaticResource ChangesCountConverter}}" />
                                    </StackPanel>

                                    <!--  操作按钮  -->
                                    <StackPanel
                                        Grid.Column="4"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        Orientation="Horizontal">
                                        <AduSkin:AduPathIconButton
                                            Margin="0,0,5,0"
                                            AduAttach:PathDataAttach.PathData="{DynamicResource Icon_MoveUp}"
                                            BorderThickness="1"
                                            Command="{Binding DataContext.MoveUpCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            FontSize="12"
                                            ToolTip="上移" />
                                        <AduSkin:AduPathIconButton
                                            Margin="0,0,5,0"
                                            AduAttach:PathDataAttach.PathData="{DynamicResource Icon_MoveDown}"
                                            BorderThickness="1"
                                            Command="{Binding DataContext.MoveDownCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            FontSize="12"
                                            ToolTip="下移" />
                                        <Grid>
                                            <AduSkin:AduPathIconButton
                                                AduAttach:PathBrushAttach.NormalPathBrush="{DynamicResource NormalForeground}"
                                                AduAttach:PathDataAttach.Margin="0"
                                                AduAttach:PathDataAttach.PathData="{DynamicResource Icon_Sync}"
                                                AduAttach:PathDataAttach.Width="12"
                                                Command="{Binding DataContext.SyncSingleCommand, RelativeSource={RelativeSource AncestorType=AduSkin:AduListBox}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="单独同步此项目"
                                                Visibility="{Binding IsSyncing, Converter={StaticResource BooleanToReVisibility}}" />
                                            <AduSkin:AduLoading
                                                Width="24"
                                                Height="24"
                                                MinWidth="24"
                                                MinHeight="24"
                                                Margin="0,0,5,0"
                                                HorizontalAlignment="Center"
                                                AduAttach:PathDataAttach.Width="10"
                                                IsActived="{Binding IsSyncing}"
                                                Type="Apple" />
                                        </Grid>
                                        <Grid Margin="0,0,5,0" Visibility="{Binding IsDotNetProject, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <AduSkin:AduPathIconButton
                                                Margin="0"
                                                AduAttach:PathDataAttach.Margin="0"
                                                AduAttach:PathDataAttach.PathData="{DynamicResource Icon_Build}"
                                                AduAttach:PathDataAttach.Width="12"
                                                Command="{Binding DataContext.BuildSingleCommand, RelativeSource={RelativeSource AncestorType=AduSkin:AduListBox}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="单独构建此项目"
                                                Visibility="{Binding IsBuilding, Converter={StaticResource BooleanToReVisibility}}" />
                                            <AduSkin:AduLoading
                                                Width="24"
                                                Height="24"
                                                MinWidth="24"
                                                MinHeight="24"
                                                HorizontalAlignment="Center"
                                                AduAttach:PathDataAttach.Width="10"
                                                IsActived="{Binding IsBuilding}"
                                                Type="Apple" />
                                        </Grid>
                                    </StackPanel>
                                </Grid>
                            </AduSkin:AduExpander.Header>
                            <AduSkin:AduExpander.Content>
                                <StackPanel Margin="0,4,0,0">
                                    <!--  错误信息显示  -->
                                    <Border
                                        x:Name="ErrorPanel"
                                        Margin="0,0,0,10"
                                        Padding="10"
                                        Background="#FFF0F0"
                                        BorderBrush="#50FF4444"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Visibility="Collapsed">
                                        <StackPanel>
                                            <TextBlock
                                                FontWeight="Bold"
                                                Foreground="#CC0000"
                                                Text="错误信息:" />
                                            <AduSkin:AduTextBox
                                                Height="Auto"
                                                MinHeight="100"
                                                MaxHeight="200"
                                                Margin="0,5,0,0"
                                                BorderBrush="{DynamicResource ErrorBrush}"
                                                FontSize="10"
                                                Foreground="{DynamicResource ErrorBrush}"
                                                IsReadOnly="True"
                                                Text="{Binding ErrorMessage}"
                                                TextWrapping="Wrap"
                                                VerticalScrollBarVisibility="Auto" />
                                        </StackPanel>
                                    </Border>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition />
                                            <ColumnDefinition Width="130" />
                                            <ColumnDefinition />
                                        </Grid.ColumnDefinitions>
                                        <!--  MSBuild版本选择  -->
                                        <AduSkin:AduFormBox
                                            Margin="0,0,10,0"
                                            Header="MSBuild:"
                                            Visibility="{Binding IsDotNetProject, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <AduSkin:AduComboBox ItemsSource="{Binding DataContext.MSBuildVersions, RelativeSource={RelativeSource AncestorType=UserControl}}" SelectedItem="{Binding SelectedMSBuildVersion}">
                                                <AduSkin:AduComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding DisplayName}" />
                                                    </DataTemplate>
                                                </AduSkin:AduComboBox.ItemTemplate>
                                            </AduSkin:AduComboBox>
                                        </AduSkin:AduFormBox>
                                        <!--  构建类型选择  -->
                                        <AduSkin:AduFormBox
                                            Grid.Column="1"
                                            Margin="0,0,10,0"
                                            Header="Config:"
                                            Visibility="{Binding IsDotNetProject, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <AduSkin:AduComboBox ItemsSource="{Binding DataContext.ConfigurationTypes, RelativeSource={RelativeSource AncestorType=UserControl}}" SelectedItem="{Binding Configuration}" />
                                        </AduSkin:AduFormBox>
                                        <!--  执行文件路径  -->
                                        <AduSkin:AduFormBox Grid.Column="2" Header="ExecuteFile:">
                                            <AduSkin:AduChooseBox Text="{Binding ExecuteFile}" />
                                        </AduSkin:AduFormBox>
                                    </Grid>
                                    <Grid Margin="0,4,0,0">
                                        <TextBlock
                                            x:Name="txtNotChange"
                                            Margin="0,10"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Foreground="#777"
                                            Text="暂无更改"
                                            Visibility="Collapsed" />
                                        <AduSkin:AduFormBox
                                            x:Name="ChangePanel"
                                            Margin="0,0,0,0"
                                            AduAttach:HeaderAttach.VerticalAlignment="Top"
                                            Header="Commit: "
                                            Visibility="Collapsed">
                                            <AduSkin:AduTextBox
                                                Grid.Column="1"
                                                Height="50"
                                                Padding="4"
                                                VerticalContentAlignment="Top"
                                                Text="{Binding CommitMessage, UpdateSourceTrigger=PropertyChanged}"
                                                ToolTip="输入该项目的提交信息" />
                                        </AduSkin:AduFormBox>
                                    </Grid>
                                </StackPanel>
                            </AduSkin:AduExpander.Content>
                        </AduSkin:AduExpander>
                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding HasError}" Value="True">
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource ErrorBrush}" />
                                <Setter TargetName="ErrorPanel" Property="Visibility" Value="Visible" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding HasChanges}" Value="True">
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource WarnBrush}" />
                                <Setter TargetName="ChangePanel" Property="Visibility" Value="Visible" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding HasChanges}" Value="False">
                                <Setter TargetName="txtNotChange" Property="Visibility" Value="Visible" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsSyncing}" Value="True">
                                <Setter TargetName="txtSyncingStatus" Property="Visibility" Value="Visible" />
                                <Setter TargetName="txtChangesCount" Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsBuilding}" Value="True">
                                <Setter TargetName="txtBuildingStatus" Property="Visibility" Value="Visible" />
                                <Setter TargetName="txtChangesCount" Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </AduSkin:AduListBox.ItemTemplate>
            </AduSkin:AduListBox>

            <!--  底部操作区  -->
            <Border
                Grid.Row="2"
                Margin="0,6,0,0"
                BorderBrush="{DynamicResource NormalBorderBrush}"
                BorderThickness="0,1,0,0">
                <StackPanel Margin="0,6,0,0">
                    <!--  Git 同步选项  -->
                    <StackPanel Orientation="Horizontal">
                        <AduSkin:AduPathIconButton
                            Width="30"
                            Height="30"
                            AduAttach:PathDataAttach.PathData="{DynamicResource Icon_Sync}"
                            BorderThickness="1"
                            Command="{Binding SyncSelectedCommand}"
                            ToolTip="一键Git同步" />
                        <AduSkin:AduFormBox Margin="5,0,0,0" Header="Pull 策略">
                            <AduSkin:AduComboBox
                                DisplayMemberPath=""
                                ItemsSource="{Binding PullStrategies}"
                                SelectedItem="{Binding GlobalPullStrategy}"
                                ToolTip="Pull" />
                        </AduSkin:AduFormBox>
                        <AduSkin:AduFormBox Margin="5,0,0,0" Header="Conflict">
                            <AduSkin:AduComboBox
                                DisplayMemberPath=""
                                ItemsSource="{Binding ConflictActions}"
                                SelectedItem="{Binding GlobalConflictAction}"
                                ToolTip="冲突时处理方式" />
                        </AduSkin:AduFormBox>
                        <AduSkin:AduSwitch
                            Margin="5,0,0,0"
                            Content="无信息时自动提交"
                            IsChecked="{Binding GlobalAutoCommitWhenNoMessage}"
                            ToolTip="未填写提交信息时，使用默认信息提交" />
                    </StackPanel>

                    <!--  构建和运行选项  -->
                    <StackPanel Margin="0,5,0,0" Orientation="Horizontal">
                        <AduSkin:AduPathIconButton
                            Width="30"
                            Height="30"
                            Margin="0,0"
                            HorizontalAlignment="Left"
                            AduAttach:PathDataAttach.PathData="{DynamicResource Icon_Build}"
                            BorderThickness="1"
                            Command="{Binding BuildSelectedCommand}"
                            ToolTip="一键生成" />

                        <AduSkin:AduPathIconButton
                            Width="30"
                            Height="30"
                            Margin="5,0,0,0"
                            AduAttach:PathDataAttach.PathData="{DynamicResource Icon_Play}"
                            AduAttach:PathDataAttach.Width="12"
                            BorderThickness="1"
                            Command="{Binding RunSelectedCommand}"
                            CommandParameter="{Binding SelectedProject}"
                            ToolTip="运行项目" />
                        <AduSkin:AduComboBox
                            MaxWidth="350"
                            Margin="5,0,0,0"
                            DisplayMemberPath="Path"
                            IsShowFilterBox="True"
                            ItemsSource="{Binding Projects}"
                            SelectedItem="{Binding SelectedProject}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
