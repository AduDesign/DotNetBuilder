<UserControl
    x:Class="DotNetBuilder.Views.WelcomeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:AduAttach="clr-namespace:AduSkin.AdditionalAttributes;assembly=AduSkin"
    xmlns:AduSkin="clr-namespace:AduSkin.Controls;assembly=AduSkin"
    xmlns:Interactivity="clr-namespace:AduSkin.Interactivity;assembly=AduSkin"
    x:Name="Root"
    Background="{DynamicResource NormalBackground}">
    <Interactivity:Interaction.Triggers>
        <Interactivity:EventTrigger EventName="Loaded">
            <Interactivity:EventToCommand Command="{Binding LoadedCommand}" CommandParameter="{Binding ElementName=Root}" />
        </Interactivity:EventTrigger>
    </Interactivity:Interaction.Triggers>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <!--  右侧操作区  -->
        <StackPanel
            Margin="0,40,0,0"
            HorizontalAlignment="Center"
            VerticalAlignment="Top">
            <!--  应用图标/标题  -->
            <Image
                Width="100"
                Height="100"
                Source="/Builder.png" />
            <TextBlock
                Margin="0,15,0,0"
                HorizontalAlignment="Center"
                FontSize="24"
                FontWeight="Bold"
                Foreground="{DynamicResource PrimaryBrush}"
                Text=".NET Project Builder" />
            <TextBlock
                Margin="0,5,0,30"
                HorizontalAlignment="Center"
                FontSize="12"
                Foreground="#888"
                Text="批量管理 Git 仓库和 .NET 项目" />
            <!--  操作按钮  -->
            <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                <AduSkin:AduButton
                    Width="120"
                    Height="34"
                    AduAttach:GuideAttach.StepDescription="点击“新建项目”。"
                    AduAttach:GuideAttach.StepGroupName="New"
                    AduAttach:GuideAttach.StepIsAutoNext="True"
                    AduAttach:GuideAttach.StepName="第一步"
                    AduAttach:GuideAttach.StepOrder="1"
                    AduAttach:GuideAttach.StepPosition="Bottom"
                    Background="{DynamicResource PrimaryBrush}"
                    Command="{Binding NewProjectCommand}"
                    Content="新建项目"
                    Foreground="White" />
                <AduSkin:AduButton
                    Width="120"
                    Height="34"
                    Margin="15,0,0,0"
                    Command="{Binding OpenProjectCommand}"
                    Content="打开项目" />
            </StackPanel>
        </StackPanel>
        <!--  项目列表  -->
        <AduSkin:AduListBox
            x:Name="list"
            Grid.Row="1"
            Margin="0,20,0,10"
            HorizontalContentAlignment="Stretch"
            ItemsSource="{Binding RecentProjects}"
            SelectedItem="{Binding SelectedProject}">
            <AduSkin:AduListBox.ItemTemplate>
                <DataTemplate>
                    <AduSkin:AduButton
                        Height="Auto"
                        HorizontalContentAlignment="Stretch"
                        Background="Transparent"
                        BorderThickness="0"
                        Command="{Binding DataContext.OpenRecentProjectCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        CommandParameter="{Binding}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Margin="5">
                                <TextBlock
                                    FontSize="13"
                                    FontWeight="Medium"
                                    Text="{Binding Name}"
                                    TextTrimming="CharacterEllipsis" />
                                <TextBlock
                                    FontSize="11"
                                    Foreground="#888"
                                    Text="{Binding FilePath}"
                                    TextTrimming="CharacterEllipsis"
                                    ToolTip="{Binding FilePath}" />
                            </StackPanel>
                            <AduSkin:AduPathIconButton
                                x:Name="btnRemove"
                                Grid.Column="1"
                                AduAttach:PathDataAttach.PathData="{DynamicResource Icon_SystemClose}"
                                Command="{Binding DataContext.RemoveProjectCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding}"
                                Visibility="Collapsed" />
                        </Grid>
                    </AduSkin:AduButton>
                    <DataTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="btnRemove" Property="Visibility" Value="Visible" />
                        </Trigger>
                    </DataTemplate.Triggers>
                </DataTemplate>
            </AduSkin:AduListBox.ItemTemplate>
            <AduSkin:AduListBox.ItemContainerStyle>
                <Style BasedOn="{StaticResource AduListBoxItem}" TargetType="AduSkin:AduListBoxItem">
                    <Setter Property="Padding" Value="6" />
                    <Setter Property="Cursor" Value="Hand" />
                </Style>
            </AduSkin:AduListBox.ItemContainerStyle>
        </AduSkin:AduListBox>
        <TextBlock
            Grid.Row="2"
            HorizontalAlignment="Center"
            FontSize="14">
            <Run Text="Copyright ©AduSkin 2026" />
            <Run Text=" | " />
            <Run Text="Version 2.0.0.0" />
        </TextBlock>
    </Grid>
</UserControl>
